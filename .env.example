# Backend API base URL. Use /api when running on Vercel, or http://localhost:3000/api for local dev.
VITE_API_URL=/api

# Telnyx credentials (server-side only; set these in the Vercel dashboard, not in the frontend)
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_PHONE_NUMBER=+1234567890

# Telnyx SIP/WebRTC credentials (used by the frontend SIP registration form)
TELNYX_SIP_USERNAME=your_telnyx_sip_username
TELNYX_SIP_PASSWORD=your_telnyx_sip_password

# Telegram forwarding (server-side only; set in Vercel dashboard)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Optional: per-number routing to different Telegram chat IDs.
# Format: phoneNumber:chatId,phoneNumber:chatId (spaces are trimmed)
# Example: +14237303370:123456789,+15551234567:987654321
TELEGRAM_NUMBER_MAP=

# Optional: secret token to verify Telegram webhook requests
# Set this and include ?secret=YOUR_SECRET in the webhook URL
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis credentials generated by Vercel Marketplace integration
UPSTASH_REDIS_KV_REST_API_READ_ONLY_TOKEN=ggAAAAAAAnExAAIgcDG3vn0mYZ_-Qk_oHkBhvtVyE4dpzdfl3j0ydT3UdPcI5Q
